 <script type="text/javascript" id="" charset="">(function(){var a=document.createElement("script");a.src="https://s.nitropay.com/ads-2113.js";a.async=!0;a.setAttribute("data-log-level","silent");a.setAttribute("data-cfasync","false");document.head.appendChild(a)})();</script><style>
/* Основной баннер */
.ncmp__banner {
  max-width: 460px !important;
  background: rgba(0, 0, 0, 0.7) !important;
  backdrop-filter: blur(16px) !important;
  -webkit-backdrop-filter: blur(16px) !important;
  box-shadow: none !important;
  border-radius: 4px !important;
  font-family: 'Inter', sans-serif !important;
}
/* Заголовок */
.ncmp__banner .ncmp__banner-info h2 {
  color: #fff !important;
}

/* Параграфы и текст */
.ncmp__banner .ncmp__banner-sections p,
.ncmp__banner .ncmp__banner-sections .ncmp__banner-section-1 p,
.ncmp__banner .ncmp__banner-sections .ncmp__banner-section-2 p,
.ncmp__banner .ncmp__banner-consent p {
  color: #fff !important;
}

.ncmp__banner .ncmp__banner-sections .ncmp__banner-section-2 p.ncmp__banner-emphasis,
.ncmp__banner .ncmp__banner-sections .ncmp__banner-section-2 p.ncmp__banner-emphasis strong {
  color: #fff;
}

/* Ссылки */
.ncmp__banner a {
  color: rgba(255, 255, 255, 0.7) !important;
  text-decoration: underline !important;
}

.ncmp__banner a span {
  color: rgba(255, 255, 255, 0.7) !important;
  text-decoration: underline !important;
}

.ncmp__banner a:hover {
  color: #fff !important;
}

.ncmp__language .ncmp__language-list {
  background: rgba(0, 0, 0, 0.9) !important;
  backdrop-filter: blur(16px) !important;
  -webkit-backdrop-filter: blur(16px) !important;
  border-radius: 4px;
}

/* Скрыть брендинг NitroPay */
.ncmp__banner .ncmp__banner-branding-btn {
  display: none !important;
}

/* Кнопка Accept */
.ncmp__banner .ncmp__btn:not(.ncmp__btn-border) {
  font-size: 14px !important;
  font-weight: 600 !important;
  border-radius: 4px !important;
  background: rgba(255, 255, 255, 0.9) !important;
  color: rgba(0, 0, 0, 0.9) !important;
  border: none !important;
  box-shadow: none !important;
}

.ncmp__banner .ncmp__btn:not(.ncmp__btn-border):hover {
  background: #fff !important;
}

/* Кнопка Advanced Settings / Customize */
